# Local Quill Configuration Template
# Copy this file to .env and fill in your values

# Document chunking configuration
CHUNK_SIZE="1000"        # Characters per chunk (1000 recommended)
CHUNK_OVERLAP="400"      # Overlap between chunks (400 recommended for high recall)

# ========== EMBEDDING & RETRIEVAL ==========
# Embedding provider: "ollama" or "huggingface"
EMBEDDING_PROVIDER="ollama"

# Embedding model name
# Ollama: "nomic-embed-text" (recommended)
# Hugging Face: "all-MiniLM-L6-v2" or others
EMBEDDING_MODEL="nomic-embed-text"

# Number of document chunks to retrieve per criterion
# Keep at 3 for local 8B models; higher values slow down inference significantly
TOP_K=3

# Point (characters) at which user text is split into separate LLM calls
USER_TEXT_SPLIT="2000"

# ========== LANGUAGE MODEL SELECTION ==========
# Use single model for all criteria (simplest)
USE_BASE_MODEL="false"

# Use per-criterion model selection from base_models.json (8B models)
# Only enable if base_models.json exists and is configured
# USE_BASE_MODEL="true"

# Use per-criterion model selection from base_models_27b.json (27B models)
# Only enable if base_models_27b.json exists and is configured
# USE_BASE_MODEL_27b="false"

# ========== LOCAL LLM (OLLAMA) ==========
# Local model for feedback generation
LOCAL_MODEL="ministral-3:8b"

# LLM temperature: 0.0 = deterministic, 1.0 = very creative
# Recommended: 0.0 (consistent feedback), 0.1 (slight variation)
TEMPERATURE=0.1

# ========== CLOUD LLM (OPENAI) ==========
# OpenAI model for comparison/baseline
# Example: "gpt-5-nano"
OPENAI_MODEL="gpt-5-nano"

# Your OpenAI API key (DO NOT COMMIT)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-"

# ========== EVALUATION ==========
# Judge model for G-Eval scoring (evaluation only)
# Recommended: "llama3.1" (good instruction-following)
JUDGE_MODEL="llama3.1"

# Embedding model for evaluation (may differ from production)
EVAL_MODEL="nomic-embed-text"

# Evaluation database path (separate from production for reproducibility)
EVAL_CHUNK_SIZE=1000
EVAL_CHUNK_OVERLAP=400
DEEPEVAL_PER_ATTEMPT_TIMEOUT_SECONDS_OVERRIDE=600

# ========== DATABASE STORAGE ==========
# Path where ChromaDB stores vectors and metadata
CHROMA_PATH="./chroma"

# ========== SECURITY & CONTENT FILTERING ==========
# Enable prompt injection detection
# true = block suspicious inputs; false = allow all inputs
USE_GUARDRAILS="true"

