CHUNK_SIZE="1000"        # Embedding: Nomic-embed-test: 750 | all-mpnet-base-v2: 500
CHUNK_OVERLAP="200"     # 20% of Chunk Size

# Path to data
COLLECTION_NAME="essay"         # Essay, Fiction
DATA_PATH="./data/styles/essay"

# Options: "ollama", "huggingface"
EMBEDDING_PROVIDER="ollama"    
# Model name for the selected embedding provider. Huggingface: "all-MiniLM-L6-v2" or "all-MiniLM-L6-v2". Ollama: "nomic-embed-text"
EMBEDDING_MODEL="nomic-embed-text"
# Point after which User Text is split into chunks and invoked seperately. (1000 words ~ 5000 characters)
USER_TEXT_SPLIT="5000" 

CHROMA_PATH="./chroma"
# LOCAL_MODEL="llama3.1"
# LOCAL_MODEL="mistral:latest"
# LOCAL_MODEL="ministral-3:8b"
# LOCAL_MODEL="minstral-nemo:12b"
# LOCAL_MODEL="qwen2,5:7b"
LOCAL_MODEL="qwen3.5:4b"
# LOCAL_MODEL="qwen3.5:9b"


TEMPERATURE=0.1 # try 0.0 -> 0.1 (highest): for the rag system (retrieval) and generation

# Number of top results to return from the similarity search. More than 3 is extremely heavy for the mini model.
TOP_K=3

# API key if G-Eval is set up with a stronger model.
# OPENAI_API_KEY=your-api-key-here
EVAL_CHUNK_SIZE=1000
EVAL_CHUNK_OVERLAP=200
EVAL_MODEL="nomic-embed-text" # all-MiniLM-L6-v2"" or 
DEEPEVAL_PER_ATTEMPT_TIMEOUT_SECONDS_OVERRIDE=600
