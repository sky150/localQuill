# Embedding: Nomic-embed-test: 750 | all-mpnet-base-v2: 500
CHUNK_SIZE="1000"        
# 20% of Chunk Size
CHUNK_OVERLAP="200"     

# Essay, Fiction
COLLECTION_NAME="essay"         
DATA_PATH="./data/styles/essay"

# Options: "ollama", "huggingface"
EMBEDDING_PROVIDER="ollama"    
# Model name for the selected embedding provider. Huggingface: "all-MiniLM-L6-v2" or "all-MiniLM-L6-v2". Ollama: "nomic-embed-text"
EMBEDDING_MODEL="nomic-embed-text"
# Point after which User Text is split into chunks and invoked seperately. (1000 words ~ 5000 characters)
USER_TEXT_SPLIT="5000" 

CHROMA_PATH="./chroma"
LOCAL_MODEL="llama3.1"
# Fiction: "qwen3.6:27b" - Essay: "llama3.1"
JUDGE_MODEL="qwen3.6:27b"
# Comparison: "gpt-5-nano" - Check #"gpt-5-mini"  
OPENAI_MODEL="gpt-5-nano"

### Don't share this in git ###
OPENAI_API_KEY="sk-"

# 0.0 better for small models. Best local models are better with 0.1
TEMPERATURE=0.1

# Number of top results to return from the similarity search. More than 3 is extremely heavy for the local model.
TOP_K=3

# all-MiniLM-L6-v2" 
EVAL_MODEL="nomic-embed-text" 
EVAL_CHUNK_SIZE=1000
EVAL_CHUNK_OVERLAP=200
DEEPEVAL_PER_ATTEMPT_TIMEOUT_SECONDS_OVERRIDE=600
