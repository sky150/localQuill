CHUNK_SIZE="500"        # Embedding: Nomic-embed-test: 750 | all-mpnet-base-v2: 500
CHUNK_OVERLAP="100"     # 20% of Chunk Size

# Path to data
DATA_PATH="./data/styles/fantasy"
COLLECTION_NAME="fantasy"

# Options: "ollama", "huggingface"
EMBEDDING_PROVIDER="huggingface"    
# Model name for the selected embedding provider. Huggingface: "all-MiniLM-L6-v2" or "all-MiniLM-L6-v2". Ollama: "nomic-embed-test"
EMBEDDING_MODEL="all-MiniLM-L6-v2"  

CHROMA_PATH="./chroma"
LOCAL_MODEL="llama3.1:8b"
